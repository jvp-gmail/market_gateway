MARKET_GATEWAY_API_KEY=change-me
# HTTP port for local dev and scripts/gateway.sh (avoid clashing with other apps on 8000).
MARKET_GATEWAY_PORT=8020
REDIS_URL=redis://localhost:6379/0
# Read timeout for normal Redis commands. Leave unset (default) for SSE: XREAD BLOCK waits up to
# EVENT_BUS_XREAD_BLOCK_MS with no bytes, which requires no socket read timeout (None).
# If you set a timeout, it must exceed EVENT_BUS_XREAD_BLOCK_MS (e.g. 65 when block is 5000 ms).
# Settings override any socket_timeout / socket_connect_timeout query params in REDIS_URL.
# REDIS_SOCKET_TIMEOUT_SECONDS=
# REDIS_SOCKET_CONNECT_TIMEOUT_SECONDS=5

# --- PostgreSQL (canonical history, asyncpg) ---
# Option A: single URL (takes precedence if non-empty)
# DATABASE_URL=postgresql+asyncpg://market_user:password@localhost:5432/marketdata
DATABASE_URL=

# Option B: same fields as Backtester4 DatabaseManager (used when DATABASE_URL is empty).
# Set a non-empty POSTGRES_PASSWORD to opt in. For trust auth without a password, use DATABASE_URL instead.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=market_user
# POSTGRES_PASSWORD=your-secret-here
POSTGRES_DBNAME=marketdata

ENABLE_SCHWAB_LIVE_DATA=false
ENABLE_REAL_TRADING=false
QUOTE_TTL_SECONDS=3
OPTION_QUOTE_TTL_SECONDS=3
OPTION_CHAIN_TTL_SECONDS=120
HISTORY_TTL_SECONDS=3600
EVENT_STREAM_NAME=stream:events
# EVENT_BUS_XREAD_BLOCK_MS=5000
# Must be a Redis **stream** key. If this name collides with an existing string/list key, /events/stream will emit stream_error events until you rename or delete the key.

# Phase 3 Schwab Trader API (do not commit real values). Generate token offline, e.g.:
#   schwab-generate-token.py --token_file /path/schwab_tokens.json --api_key ... --app_secret ... --callback_url https://127.0.0.1:8182
# SCHWAB_CLIENT_ID=
# SCHWAB_CLIENT_SECRET=
# SCHWAB_REDIRECT_URI=https://127.0.0.1:8182
# SCHWAB_TOKEN_FILE=/secure/path/outside/repo/schwab_tokens.json
# SCHWAB_MIN_REQUEST_INTERVAL_SECONDS=0.12

# Phase 4 (part 2): Schwab WebSocket LEVELONE_EQUITIES → Redis event stream (requires ENABLE_SCHWAB_LIVE_DATA + token).
# ENABLE_SCHWAB_STREAMING=false
# SCHWAB_STREAM_EQUITY_SYMBOLS=SPY,QQQ,/ES
# Optional: comma-separated option symbols (Schwab OSI or gateway underscore ids) → LEVELONE_OPTIONS.
# SCHWAB_STREAM_OPTIONS_SYMBOLS=SPY   260601C00756000
# Futures: leading slash (/ES, /MES) → LEVELONE_FUTURES; otherwise → LEVELONE_EQUITIES.
# SCHWAB_STREAM_RECONNECT_SECONDS=5
# SCHWAB_STREAMING_DEBUG=false  # true = DEBUG logs for schwab-py WebSocket (Send/Receive JSON); disable after troubleshooting.

# Phase 4 (part 1): synthetic equity_quote events for GET /events/stream testing (no Schwab WebSocket).
# ENABLE_QUOTE_STREAM_STUB=false
# QUOTE_STREAM_STUB_SYMBOLS=/MES,/ES
# QUOTE_STREAM_STUB_INTERVAL_SECONDS=5
