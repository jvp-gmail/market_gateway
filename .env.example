MARKET_GATEWAY_API_KEY=change-me
# HTTP port for local dev and scripts/gateway.sh (avoid clashing with other apps on 8000).
MARKET_GATEWAY_PORT=8020
REDIS_URL=redis://localhost:6379/0

# --- PostgreSQL (canonical history, asyncpg) ---
# Option A: single URL (takes precedence if non-empty)
# DATABASE_URL=postgresql+asyncpg://market_user:password@localhost:5432/marketdata
DATABASE_URL=

# Option B: same fields as Backtester4 DatabaseManager (used when DATABASE_URL is empty).
# Set a non-empty POSTGRES_PASSWORD to opt in. For trust auth without a password, use DATABASE_URL instead.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=market_user
# POSTGRES_PASSWORD=your-secret-here
POSTGRES_DBNAME=marketdata

ENABLE_SCHWAB_LIVE_DATA=false
ENABLE_REAL_TRADING=false
QUOTE_TTL_SECONDS=3
OPTION_QUOTE_TTL_SECONDS=3
OPTION_CHAIN_TTL_SECONDS=120
HISTORY_TTL_SECONDS=3600
EVENT_STREAM_NAME=stream:events
# EVENT_BUS_XREAD_BLOCK_MS=5000

# Phase 3+ Schwab (do not commit real values)
# SCHWAB_CLIENT_ID=
# SCHWAB_CLIENT_SECRET=
# SCHWAB_REDIRECT_URI=
# SCHWAB_TOKEN_FILE=/secure/path/outside/repo/schwab_tokens.json
